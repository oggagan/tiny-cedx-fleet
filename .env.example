# Copy to .env for the real-LLM path (REPLAY_LLM=false). The default graded path is
# REPLAY_LLM=true and needs NO key (it replays committed transcripts/).
#
# Any OpenAI-compatible endpoint works. Reference values below target DeepSeek,
# which exposes deepseek-chat (cheap) and deepseek-reasoner (strong) — a natural
# cheap/strong pair for the model router.
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MODEL_STRONG=deepseek-reasoner

# The grader may instead point these at gpt-4o-mini / claude-3-5-haiku / gemini-1.5-flash.
